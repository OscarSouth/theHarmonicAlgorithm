-- ──────────────────────────────────────────────────────────
-- 7m24s Spectral Narrative (444s quantum)
-- ──────────────────────────────────────────────────────────
--
-- 11 nodes = 10 compositional + 1 silence.
-- Motive arc: Exposition(1-3) -> Development(4-5) -> Cumulation(6-7) -> Resolution(8-10)

let
  form =                              -- 7m24s spectral narrative (454s loop)
    [ at     0.0   0.0   0.0   s     -- exposition: emergence
    , at    55.5   0.15  0.3   s     -- 1/8: establishing
    , at   111.0   0.3   0.45  s     -- 1/4: inciting event
    , at   166.5   0.5   0.6   s     -- 3/8: development tension
    , at   222.0   0.4   0.5   s     -- 1/2: the swerve
    , at   275.0   0.8   0.85  s     -- PRIMARY: cumulation
    , at   333.0   1.0   1.0   s     -- 3/4: peak
    , at   380.0   0.6   0.7   s     -- SECONDARY: resolution begins
    , at   420.0   0.2   0.3   s     -- TERTIARY: convergence
    , at   444.0   0.0   0.0   s     -- fine: equilibrium
    , at   454.0   0.0   0.0   s     -- silence (10s gap)
    ]


