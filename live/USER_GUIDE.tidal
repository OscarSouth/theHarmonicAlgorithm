-- 12.8 MIDI Helpers (BootTidal.hs)
-- ──────────────────────────────────────────────────────────

-- ch :: Int -> Pattern ValueMap
--   MIDI channel (ch 01, ch 02, etc.)

-- vel :: Pattern Double -> Pattern ValueMap
--   Velocity/amplitude

-- oct :: Int -> Pattern ValueMap
--   Octave shift (|+ oct 1, |- oct 2)

-- setbpm :: Double -> IO ()
--   Set tempo (setbpm 120)


-- ──────────────────────────────────────────────────────────
-- 12.9 Common Patterns
-- ──────────────────────────────────────────────────────────

-- Single-state form (no arc):
-- let k = formK tempo [at 0 1 1 prog]

-- Full chords (flow voicing):
-- d01 $ arrange (0,1) flow id (rep prog 1) k (-9,9) ["[0,1,2,3]/4"] # ch 01

-- Bass line (root voicing, low octave):
-- d02 $ arrange (0,1) root id (rep prog 1) k (-9,9) ["0*2"] # ch 01 |- oct 2

-- Arpeggios (flow voicing):
-- d03 $ arrange (0,1) flow id (rep prog 1) k (-9,9) ["0 1 2 3 4 5 6 7"] # ch 01

-- With forward overlap:
-- arrange (0,1) flow (overlapF 0) r k (-9,9) pats

-- Multi-voice stack with kinetics ranges:
-- d01 $ stack [
--   arrange (0.5,1) flow id r k (-9,9) ["[0,1,2,3]/4"] # ch 01,
--   arrange (0,1) root id r k (-9,9) ["0*2"] # ch 01 |- oct 2
-- ] |* vel (kDynamic k)

-- Launcher block pattern:
-- p01 f r d k = d01 $ do
--   let o = ch 01
--   f $ arrange (0,1) flow id r k (-9,9) ["pattern"]
--     # o |* vel (kDynamic k) |* vel d

-- Groove (sub/kick following harmonic root):
-- p "subKick" $ subKick fund (rep prog 1) 1 k
--   (1/4, "[1(3,8)]/2", "[1(5,8,-2)]/2", "[1(3,8)]/2")


-- ──────────────────────────────────────────────────────────
-- 12.10 Troubleshooting
-- ──────────────────────────────────────────────────────────

-- Neo4j not running:
--   docker compose up -d neo4j
--   curl http://localhost:7474  (verify accessible)

-- BootTidal.hs not loaded:
--   :script /path/to/BootTidal.hs  (in TidalCycles)

-- MIDI not working:
--   Check MIDI device on channel (tidal-piano on ch 01)
--   Verify SuperDirt MIDI config in SuperCollider

-- Pattern not playing:
--   Check pattern syntax (use "" for strings)
--   Verify chord selection pattern (warp "[1 2 3 4]/4")
--   Try hush' and restart


