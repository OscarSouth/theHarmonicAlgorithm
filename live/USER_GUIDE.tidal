-- ── QUICK REFERENCE ──
--
-- Generation:
--   start <- lead "C maj"                          -- or initCadenceState
--   s <- seek "none" $ cue start $ len 4 $ entropy 0.5 $ gen
--
-- Context modifiers (compose with $, right-to-left):
--   hContext, hcOvertones, hcKey, hcRoots, hcPedal,
--   consonant, dissonant, invSkip
--
-- Voicing functions: flow, grid, lite, root, fund
--
-- Chord selection: rep s 1, warp "[1 2 3 4]/4"
--
-- Arrangement: arrange (lo,hi) k (-9,9) voicing modifier [patterns] # ch N
--              arrange' = squeeze variant
--
-- Form node: at time kinetics dynamics progression
-- IK bundle: iK tempo [nodes] chordSelection
--
-- Manipulation: rotate, excerpt, transposeP, reverse, fuse, fuse2,
--               interleave, expandP, insert, switch, clone, extract,
--               progOverlap, progOverlapF, progOverlapB

hush
