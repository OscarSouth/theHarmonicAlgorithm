-- ============================================================================
-- V. PAS DES FURIES
-- ============================================================================
--
-- From the myth: Orpheus enters the underworld and is immediately set upon
-- by the Furies (Erinyes) -- chthonic deities of vengeance who guard the
-- boundary between living and dead. They swarm, punish, and attempt to
-- destroy the intruder.
--
-- Stravinsky's treatment is paradoxically restrained even here. He stated:
-- "The music for the Furies is soft, and constantly remains on the soft level."
-- Even the threatening Furies are "spectral and restrained," depicted with
-- "agitated exclamations from the strings" rather than orchestral bombast.
-- Yet the music is undeniably violent in its rhythmic aggression -- explosive,
-- jagged, asymmetrical. Frantic ostinatos and polytonal clashes create a
-- hostile sonic landscape.
--
-- As the movement progresses, Orpheus begins to resist musically: the harp
-- (lyre) tries to pierce through the cacophony with isolated chords but is
-- drowned by orchestral tuttis. The Furies' energy fragments, their ostinatos
-- break down, and they are gradually subdued by the impending power of
-- Orpheus's song.
--
-- This is the first Dionysian eruption in the ballet -- chaos against the
-- Apollonian restraint that has dominated. Its eventual subsidence is a
-- victory of art (Apollo's gift) over primal fury.
--
-- Reimagination: Eb diminished starting point -- maximally unstable. No key
-- constraint, dissonance drift. High entropy for unpredictable, jagged
-- harmony. Stravinsky/Bartok blend for rhythmic aggression. All strings
-- in grid voicing (raw, angular), with horns and timpani.
-- ============================================================================

tempo = 92

start <- lead "Eb dim"

let ctx = dissonant
        $ hcKey "*"
        $ hContext

s <- seek "stravinsky:70 bartok:30" $ cue start $ tonal ctx $ len 8 $ entropy 0.7 $ gen

-- Form: ~184s loop (174s music + 10s silence)
-- Arc: explosive -> sustained fury -> heavy -> lyre resistance -> fragmentation -> subdued
form =
  [ at    0    0.0   0.0   s     -- silence before the storm
  , at    3    0.8   0.8   s     -- explosive entry: the Furies attack
  , at   27    0.9   0.9   s     -- sustained fury, swarming
  , at   57    0.8   0.8   s     -- heavy rhythmic block, underworld mechanism
  , at   87    0.7   0.7   s     -- lyre attempts to break through
  , at  117    0.5   0.5   s     -- energy fragments, ostinatos break down
  , at  147    0.2   0.2   s     -- subdued: grumbling low strings
  , at  174    0.0   0.0   s     -- stillness
  , at  184    0.0   0.0   s     -- silence gap
  ]

-- ── ORCHESTRAL BLOCKS ───────────────────────────────────

-- The Furies: strings + brass in aggressive grid voicing
furies f k d = p "furies" $ do
  let vl = voiceLines {_vl = "~"
        , soprano = "[0 1 2 3]*4"
        , alto    = "[3 2 0 1]*4"
        , tenor   = "[1 3 0 2]*4"
        , bass    = "[0 3 0 -1]*2"
        }
  f
    $ stack [silence
        , violin1    (0, 1) k vl grid Soprano
        , violin2    (0, 1) k vl grid Alto
        , viola      (0, 1) k vl grid Tenor
        , cello      (0, 1) k vl grid Bass
        , contrabass (0, 1) k vl grid Bass8vb
        , horn       (0, 1) k vl flow Soprano
        , timpani    (0, 1) k vl grid Bass8vb
    ] |* vel d

-- Orpheus's lyre: attempting to break through (enters at higher kinetics)
lyreResist f k d = p "lyre" $ do
  let vl = voiceLines {_vl = "~"
        , soprano = "[3 . 2 . 1 . 0 .]/4"
        }
  f
    $ stack [silence
        , harp (0.5, 0.8) k vl flow Soprano
    ] |* vel d

-- ── LAUNCHER ────────────────────────────────────────────

do
  let
    f = id
    d = (* 1)
    k = iK tempo form (warp "[1 2 3 4 3 2 1 4]/4")
  putStrLn "ORPHEUS — V. Pas des furies"
  mapM_ id [hush, setbpm tempo
    ,furies    f k  $ d 0.9
    ,lyreResist f k $ d 0.6
    ]

hush''
