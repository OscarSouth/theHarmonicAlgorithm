-- ============================================================================
-- XII. PAS D'ACTION 2 — THE BACCHANTES
-- ============================================================================
--
-- From the myth: The Bacchantes (Maenads) -- female followers of Dionysus,
-- god of wine and ecstasy -- find Orpheus wandering in grief. In some
-- versions, they are enraged that he has rejected their advances, devoted
-- only to his lost Eurydice. In others, they represent the fundamental
-- incompatibility between Apollonian art (order, measure, light) and
-- Dionysian nature (chaos, intoxication, darkness). They tear Orpheus apart
-- and smash his lyre -- the destruction of beauty by brute force.
--
-- Stravinsky unleashes the only true fortissimo in the entire ballet.
-- After 25 minutes of Apollonian restraint, the music erupts into "loudness
-- and ferocity, with slashing chords in the manner of Le Sacre du printemps."
-- The passage reaches fortississimo (fff) at the moment of dismemberment.
-- Fast, uneven meters (5/8, 7/8) drive the violence. Brass features
-- flutter-tonguing and harsh accents. The frenzy peaks as the lyre is
-- smashed, then abruptly cuts off -- a few scattered twitching motifs,
-- then dark silence.
--
-- This Dionysian eruption gains its devastating power precisely because it
-- interrupts the restrained Apollonian world that has dominated the ballet.
-- The destruction is total but brief -- Dionysus cannot sustain; only
-- Apollo endures.
--
-- Reimagination: C diminished starting point -- maximally unstable.
-- No key constraint, dissonance drift. Maximum entropy (0.9) for chaotic,
-- unpredictable harmony. Stravinsky for rhythmic savagery. Every instrument
-- in grid voicing (no voice leading smoothing -- raw angular impact).
-- Fast tempo, aggressive voice line patterns.
-- ============================================================================

tempo = 104

start <- lead "C dim"

let ctx = dissonant
        $ hcKey "*"
        $ hContext

s <- seek "stravinsky" $ cue start $ tonal ctx $ len 8 $ entropy 0.9 $ gen

-- Form: ~152s loop (142s music + 10s silence)
-- Arc: silence -> explosion -> tearing -> frenzy peak -> abrupt cutoff -> twitching -> dark
form =
  [ at    0    0.0   0.0   s     -- silence before violence
  , at    3    0.9   0.9   s     -- explosive: sudden, savage
  , at   25    0.95  1.0   s     -- tearing: fast uneven meters, fff
  , at   55    1.0   1.0   s     -- frenzy peaks: the lyre is smashed
  , at   85    0.4   0.4   s     -- violence abruptly cuts off
  , at  110    0.1   0.1   s     -- scattered twitching, dark silence
  , at  142    0.0   0.0   s     -- void
  , at  152    0.0   0.0   s     -- silence gap
  ]

-- ── ORCHESTRAL BLOCKS ───────────────────────────────────

-- The Bacchantes: full orchestra in raw grid voicing
bacchantes f r k d = p "bacchantes" $ do
  let vl = voiceLines {_vl = "~"
        , soprano = "[0 3 1 2]*4"
        , alto    = "[2 0 3 1]*4"
        , tenor   = "[1 2 0 3]*4"
        , bass    = "[0 -1 3 0]*4"
        }
  f
    $ stack [silence
        -- Strings: raw, angular
        , violin1    (0, 1) grid Soprano    r k vl
        , violin2    (0, 1) grid Alto       r k vl
        , viola      (0, 1) grid Tenor      r k vl
        , cello      (0, 1) grid Bass       r k vl
        , contrabass (0, 1) grid Bass8vb    r k vl
        -- Brass: slashing
        , horn       (0, 1) grid Soprano    r k vl
        , trombone   (0, 1) grid Tenor      r k vl
        , basstrom   (0, 1) grid Bass8vb    r k vl
        -- Percussion: pounding
        , timpani    (0, 1) grid Bass8vb    r k vl
    ] |* vel (kDynamic k) |* vel d

-- ── LAUNCHER ────────────────────────────────────────────

do
  let
    r = warp "[1 2 3 4 3 2 1 4]/4"
    f = id
    d = (* 1)
    k = formK tempo form
  putStrLn "ORPHEUS — XII. Pas d'action 2 (The Bacchantes)"
  mapM_ id [hush, setbpm tempo
    ,bacchantes f r k  $ d 0.95
    ]

hush''
